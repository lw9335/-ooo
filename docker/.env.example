# Copy this file to `.env` in the docker/ folder before running docker compose.
# docker compose automatically reads docker/.env

# PostgreSQL
POSTGRES_USER=qixiu
POSTGRES_PASSWORD=please_change_this_password
POSTGRES_DB=qixiu

# JWT (use a long random string in production)
JWT_SECRET=please_change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Auto turn WORKING -> IDLE after N hours
AUTO_IDLE_HOURS=5

# WeCom (企业微信) self-built app
WEWORK_CORP_ID=
WEWORK_AGENT_ID=
WEWORK_SECRET=

# Mobile H5 base url (WeCom trusted domain), e.g. https://m.example.com
MOBILE_BASE_URL=https://m.example.com
