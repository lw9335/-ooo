# ============ 通用 ============
NODE_ENV=development

# ============ 后端 API ============
API_PORT=3000
# JWT 密钥（上线务必改成随机长字符串）
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ============ PostgreSQL ============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=qixiu
POSTGRES_PASSWORD=qixiu_pass_change_me
POSTGRES_DB=qixiu
# Prisma 连接串（compose 内部访问用 host=postgres）
DATABASE_URL=postgresql://qixiu:qixiu_pass_change_me@localhost:5432/qixiu?schema=public

# ============ Redis ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ 工作中自动转空闲（小时） ============
AUTO_IDLE_HOURS=5

# ============ 企业微信自建应用 ============
WEWORK_CORP_ID=your_corp_id
WEWORK_AGENT_ID=your_agent_id
WEWORK_SECRET=your_app_secret
# 移动端 H5 地址（企业微信可信域名 / 免登回调）
MOBILE_BASE_URL=http://localhost:5174

# ============ 前端可访问的 API 地址 ============
# 电脑后台 / 移动端构建时注入
VITE_API_BASE_URL=http://localhost:3000
